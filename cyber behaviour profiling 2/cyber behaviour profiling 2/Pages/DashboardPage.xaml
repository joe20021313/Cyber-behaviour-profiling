<Page x:Class="cyber_behaviour_profiling_2.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage">
          <Page.Resources>

            <Style x:Key="SectionCard" TargetType="Border">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="12" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#22000000" BlurRadius="8" ShadowDepth="2" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>

            <Style x:Key="SectionDescription" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#666" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>
        </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Account" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Manage your account, sign-in options and sync settings." Style="{StaticResource SectionDescription}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Width="120" Height="32" Content="Manage account"   />
                            <Button Width="120" Height="32" Content="Sign in" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Personalization" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Appearance, theme and layout preferences." Style="{StaticResource SectionDescription}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Theme:" VerticalAlignment="Center" Width="80"/>
                            <ComboBox Width="170"  Margin="8,0,0,0">
                                <ComboBoxItem>Light</ComboBoxItem>
                                <ComboBoxItem>Dark</ComboBoxItem>
                                <ComboBoxItem>System</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Notifications" Style="{StaticResource SectionHeader}" />
                        
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Detection" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Configure detection methods and thresholds." Style="{StaticResource SectionDescription}" />
                        <StackPanel Orientation="Vertical" >
                            <CheckBox x:Name="ChkEnableDetection" Content="Enable Detection" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Method:" VerticalAlignment="Center" Width="80"/>
                                <ComboBox x:Name="CmbMethod" Width="170" Margin="8,0,0,0">
                                    <ComboBoxItem>Heuristic</ComboBoxItem>
                                    <ComboBoxItem>Signature</ComboBoxItem>
                                    <ComboBoxItem>Hybrid</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Sensitivity:" VerticalAlignment="Center" Width="80"/>
                                <Slider x:Name="SldSensitivity" Minimum="1" Maximum="10" Value="5" Width="170" Margin="8,0,0,0" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <Button Content="Save" Width="100" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>