<Page x:Class="cyber_behaviour_profiling_2.Pages.BaselinesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Baselines"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Background"      Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style x:Key="CardDesc" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"      Value="0,0,0,14"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20,14,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- RECORDING HEADER -->
        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="20,18" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Record Process Baseline" Style="{StaticResource CardTitle}"/>
                <TextBlock Style="{StaticResource CardDesc}" Text="Build a new baseline array by letting the process run while being tracked. This trains the True KNN algorithm about safe behaviour."/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="ProcessDropdown" Grid.Column="0" IsEditable="False" VerticalAlignment="Center" Height="32" Padding="12,0" SelectionChanged="ProcessDropdown_SelectionChanged"/>
                    <TextBlock x:Name="DropdownHint" Text="Select a running process..." IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <ui:Button x:Name="BrowseBtn" Content="Browse" Grid.Column="2" VerticalAlignment="Center" Click="BrowseButton_Click"/>
                    <ui:Button x:Name="RefreshBtn" Content="Refresh" Grid.Column="4" VerticalAlignment="Center" Click="RefreshProcessList_Click"/>
                    
                    <ui:Button x:Name="StartStopBtn" Content="Start Recording" Appearance="Primary" Grid.Column="6" VerticalAlignment="Center" Click="StartStop_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Pick a process from the list, then hit Start Recording." FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <ProgressBar x:Name="RecordProgress" Visibility="Collapsed" IsIndeterminate="True" Margin="0,4,0,8" Height="4"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <ui:Button x:Name="SaveBaselineBtn" Content="Save Baseline" Appearance="Secondary" IsEnabled="False" Click="SaveBaseline_Click"/>
                    <ui:Button x:Name="CancelBtn" Content="Cancel" Appearance="Transparent" Margin="6,0,0,0" Visibility="Collapsed" Click="CancelBaseline_Click"/>
                </StackPanel>
                <TextBlock x:Name="BaselinePathLabel" Margin="0,6,0,0" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- BASELINE LIST -->
        <Border Grid.Row="1" Style="{StaticResource PanelCard}" Padding="16" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Active Baselines" Style="{StaticResource CardTitle}" Margin="4,0,0,12"/>

                <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No baselines available" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="BaselineListPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
