<Page x:Class="cyber_behaviour_profiling_2.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Background"      Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20,18"/>
            <Setter Property="Margin"          Value="0,0,0,16"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style x:Key="CardDesc" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"      Value="0,0,0,14"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,20" MaxWidth="560" HorizontalAlignment="Left">

            <!-- POWERSHELL LOGGING -->
            <Border Style="{StaticResource PanelCard}">
                <StackPanel>
                    <TextBlock Text="PowerShell Logging" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="Enable ScriptBlock logging so the tool can monitor PowerShell commands executed by monitored processes. Requires administrator privileges. Disable when not in use."
                               Style="{StaticResource CardDesc}"/>
                    <TextBlock x:Name="LoggingStatusText"
                               FontSize="12" FontWeight="SemiBold"
                               Margin="0,0,0,14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="EnableLoggingButton"  Content="Enable Logging"
                                   Appearance="Primary" Margin="0,0,10,0"
                                   Click="EnableLogging_Click"/>
                        <ui:Button x:Name="DisableLoggingButton" Content="Disable Logging"
                                   Appearance="Secondary"
                                   Click="DisableLogging_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SYSMON COVERAGE -->
            <Border Style="{StaticResource PanelCard}">
                <StackPanel>
                    <TextBlock Text="Sysmon Configuration" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="Sysmon provides kernel-level visibility for LSASS credential access, process injection, and process hollowing. All three require Sysmon to be installed and configured, click the button below to apply the profiler's recommended configuration. Requires administrator privileges. Disable when not in use."
                               Style="{StaticResource CardDesc}"/>

                    <!-- Status rows -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Sysmon Service"
                                   Grid.Row="0" Grid.Column="0"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="SysmonServiceStatus"
                                   Grid.Row="0" Grid.Column="1"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <TextBlock Text="LSASS Access Detection  (EventID 10)"
                                   Grid.Row="1" Grid.Column="0"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="SysmonEv10Status"
                                   Grid.Row="1" Grid.Column="1"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <TextBlock Text="Thread Injection Detection  (EventID 8)"
                                   Grid.Row="2" Grid.Column="0"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="SysmonEv8Status"
                                   Grid.Row="2" Grid.Column="1"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <TextBlock Text="Process Hollowing Detection  (EventID 25)"
                                   Grid.Row="3" Grid.Column="0"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="SysmonEv25Status"
                                   Grid.Row="3" Grid.Column="1"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Refresh"
                                   Appearance="Secondary" Margin="0,0,10,0"
                                   Click="RefreshSysmon_Click"/>
                        <ui:Button x:Name="ApplySysmonConfigButton"
                                   Content="Apply Profiler Config"
                                   Appearance="Primary"
                                   Click="ApplySysmonConfig_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
