<Page x:Class="cyber_behaviour_profiling_2.Pages.DetectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Detection"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <Page.Resources>

        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Background"      Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>

    </Page.Resources>

    <Grid Margin="20,14,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- INPUT BAR -->
        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="DropZone" Grid.Column="0"
                        AllowDrop="True" CornerRadius="6" Padding="10,6"
                        BorderThickness="1.5"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        DragEnter="DropZone_DragEnter"
                        DragLeave="DropZone_DragLeave"
                        Drop="DropZone_Drop">
                    <Grid>
                        <TextBlock x:Name="HintText"
                                   Text="Drop .exe  or type process name..."
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBox x:Name="ProcessInput"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="13" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextFillColorPrimaryBrush}"
                                 TextChanged="ProcessInput_TextChanged"/>
                    </Grid>
                </Border>

                <ui:Button Grid.Column="1" Content="Browse"
                           Margin="8,0,0,0" Click="BrowseButton_Click"/>
                <ui:Button x:Name="StartButton" Grid.Column="2" Content="Start"
                           Appearance="Primary" Margin="8,0,0,0" Click="StartButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelCard}" Margin="0,0,12,0" Padding="20,22,20,18">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionLabel}"
                               Text="THREAT SCORE"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock x:Name="ScoreLabel"
                               Text="0" FontSize="76" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <Border x:Name="SeverityBadge"
                            CornerRadius="4" Padding="16,4"
                            HorizontalAlignment="Center" Margin="0,0,0,22"
                            Background="#30888888">
                        <TextBlock x:Name="SeverityLabel"
                                   Text="BENIGN" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Border>

                    <Grid x:Name="ScoreBarContainer" Height="14"
                          SizeChanged="ScoreBarContainer_SizeChanged">
                        <Border CornerRadius="7" Opacity="0.2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#27AE60" Offset="0"/>
                                    <GradientStop Color="#F39C12" Offset="0.5"/>
                                    <GradientStop Color="#E74C3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="ScoreBarFill" CornerRadius="7">
                            <Border.Clip>
                                <RectangleGeometry x:Name="ScoreClip" Rect="0,0,0,14"/>
                            </Border.Clip>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#27AE60" Offset="0"/>
                                    <GradientStop Color="#F39C12" Offset="0.5"/>
                                    <GradientStop Color="#E74C3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <TextBlock Text="0"    FontSize="9" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="300+" FontSize="9" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="DetailRowDef" Height="0"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource PanelCard}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionLabel}"
                                   Text="EVENTS" Margin="0,0,0,12"/>

                        <TextBlock x:Name="EmptyEventsText" Grid.Row="1"
                                   Text="No events yet — start monitoring a process."
                                   FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="EventTiles">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource TileButton}"
                                                Tag="{Binding}" Click="EventTile_Click"
                                                Width="140" Height="82"
                                                Margin="0,0,10,10" Cursor="Hand">
                                            <Border CornerRadius="8" Padding="12,10"
                                                    Width="140" Height="82"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding EventType}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                                                        <Border Background="{Binding CategoryBrush}"
                                                                CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding ShortCategory}"
                                                                       FontSize="9" Foreground="White"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding CountLabel}"
                                                                   FontSize="11" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource PanelCard}"
                        Margin="0,10,0,0" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock x:Name="DetailTitle"
                                       Style="{StaticResource SectionLabel}"
                                       Text="TIMELINE" VerticalAlignment="Center"
                                       DockPanel.Dock="Left"/>
                            <Button Content="✕" DockPanel.Dock="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" FontSize="12"
                                    HorizontalAlignment="Right"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Click="CloseDetail_Click"/>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TimelineList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="65"/>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}"
                                                       FontSize="10" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <Ellipse Grid.Column="1"
                                                     Width="7" Height="7"
                                                     Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Raw}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       VerticalAlignment="Center" Margin="5,0,0,0"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- GREY OVERLAY -->
        <Border x:Name="GreyOverlay" Grid.RowSpan="2"
                Background="#99000000" Visibility="Collapsed"
                MouseDown="GreyOverlay_MouseDown"/>

        <!-- EXPANDABLE REPORT CARD -->
        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Margin="0,10,0,0">
            <StackPanel>

                <!-- Clickable header strip -->
                <Button Style="{StaticResource TileButton}" Cursor="Hand"
                        Click="ReportHeader_Click">
                    <DockPanel Margin="16,12">
                        <TextBlock Style="{StaticResource SectionLabel}"
                                   Text="Timeline of Events" VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>
                        <TextBlock x:Name="ReportChevron" Text="^"
                                   FontSize="9" VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                </Button>

                <!-- Animated content (MaxHeight goes 0 → 260) -->
                <Border x:Name="ReportCardContent" MaxHeight="0" ClipToBounds="True">
                    <Grid Margin="16,0,16,14" Height="220">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReportList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="12,8" CornerRadius="6"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{Binding CategoryBrush}"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ShortCategory}"
                                                       FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding EventType}"
                                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CountLabel}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</Page>