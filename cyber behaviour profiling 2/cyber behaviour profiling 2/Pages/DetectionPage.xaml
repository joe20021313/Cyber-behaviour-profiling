<Page x:Class="cyber_behaviour_profiling_2.Pages.DetectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Detection"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <Page.Resources>

        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Background"      Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>

    </Page.Resources>

    <Grid Margin="20,14,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- INPUT BAR -->
        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <ComboBox x:Name="ProcessDropdown"
                                  IsEditable="False" FontSize="13"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ProcessDropdown_SelectionChanged"/>
                        <TextBlock x:Name="DropdownHint"
                                   Text="Select a running process..."
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <ui:Button Grid.Column="1" Content="Add"
                               Margin="8,0,0,0" Click="AddProcess_Click"/>
                    <ui:Button Grid.Column="2" Content="Browse"
                               Margin="8,0,0,0" Click="BrowseButton_Click"/>
                    <ui:Button Grid.Column="3" Content="Refresh"
                               Margin="8,0,0,0" Click="RefreshProcessList_Click"/>
                    <ui:Button x:Name="StartButton" Grid.Column="4" Content="Start"
                               Appearance="Primary" Margin="8,0,0,0" Click="StartButton_Click"/>
                </Grid>

                <!-- Selected processes as removable tags -->
                <ItemsControl x:Name="SelectedProcessList" Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="8,4" Margin="0,0,6,4"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Button Content="✕" FontSize="10"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4,0" Margin="6,0,0,0"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Tag="{Binding}" Click="RemoveProcess_Click"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: RESULT PANEL -->
            <Border Style="{StaticResource PanelCard}" Margin="0,0,12,0" Padding="20,22,20,18">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionLabel}"
                               Text="RESULT"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <Viewbox MaxHeight="50" Stretch="Uniform"
                             HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock x:Name="ScoreLabel"
                                   Text="READY" FontSize="42" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Viewbox>

                    <Border x:Name="SeverityBadge"
                            CornerRadius="4" Padding="16,4"
                            HorizontalAlignment="Center" Margin="0,0,0,22"
                            Background="#30888888">
                        <TextBlock x:Name="SeverityLabel"
                                   Text="BENIGN" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Border>

                    <TextBlock x:Name="ResultSummaryText"
                               Text="Enter a process name and start monitoring."
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Margin="0,0,0,18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <ui:Button x:Name="ShowResultsButton"
                               Content="Show Results"
                               Appearance="Primary"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"
                               Visibility="Collapsed"
                               Click="ShowResults_Click"/>

                    <Grid x:Name="ScoreBarContainer" Height="14" Visibility="Collapsed">
                        <Border CornerRadius="7" Opacity="0.2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#27AE60" Offset="0"/>
                                    <GradientStop Color="#F39C12" Offset="0.5"/>
                                    <GradientStop Color="#E74C3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="ScoreBarFill" CornerRadius="7">
                            <Border.Clip>
                                <RectangleGeometry x:Name="ScoreClip" Rect="0,0,0,14"/>
                            </Border.Clip>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#27AE60" Offset="0"/>
                                    <GradientStop Color="#F39C12" Offset="0.5"/>
                                    <GradientStop Color="#E74C3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- RIGHT: EVENTS + DETAIL -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="DetailRowDef" Height="0"/>
                </Grid.RowDefinitions>

                <!-- ACTIVITY TILES -->
                <Border Style="{StaticResource PanelCard}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionLabel}"
                                   Text="ACTIVITY" Margin="0,0,0,12"/>

                        <WrapPanel x:Name="ProcessTabStrip"
                                   Grid.Row="1"
                                   Visibility="Collapsed"
                                   Orientation="Horizontal"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="EmptyEventsText" Grid.Row="2"
                                   Text="No events yet, start monitoring a process."
                                   FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TileContainer" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- DETAIL PANEL (shown when tile is clicked) -->
                <Border Grid.Row="1" Style="{StaticResource PanelCard}"
                        Margin="0,10,0,0" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock x:Name="DetailTitle"
                                       Style="{StaticResource SectionLabel}"
                                       Text="DETAILS" VerticalAlignment="Center"
                                       DockPanel.Dock="Left"/>
                            <Button Content="X" DockPanel.Dock="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" FontSize="12"
                                    HorizontalAlignment="Right"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Click="CloseDetail_Click"/>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TimelineList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,5" Padding="10,7" CornerRadius="6"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ShortName}"
                                                           FontSize="11" TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding FullDetail}"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CountLabel}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TimeDisplay}"
                                                           FontSize="10" Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- GREY OVERLAY -->
        <Border x:Name="GreyOverlay" Grid.RowSpan="2"
                Background="#99000000" Visibility="Collapsed"
                MouseDown="GreyOverlay_MouseDown"/>

        <!-- EXPANDABLE TIMELINE PANEL -->
        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Margin="0,10,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel>

                <Button Style="{StaticResource TileButton}" Cursor="Hand"
                        Click="ReportHeader_Click">
                    <Border Background="Transparent" CornerRadius="10" Padding="0"
                            BorderThickness="0">
                        <DockPanel Margin="16,12">
                            <TextBlock Style="{StaticResource SectionLabel}"
                                       Text="TIMELINE" VerticalAlignment="Center"
                                       DockPanel.Dock="Left"/>
                            <TextBlock x:Name="ReportChevron" Text="▲"
                                       FontSize="9" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       DockPanel.Dock="Right"/>
                        </DockPanel>
                    </Border>
                </Button>

                <Border x:Name="ReportCardContent" MaxHeight="0" ClipToBounds="True">
                    <Grid Margin="16,0,16,14" Height="220">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReportList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}"
                                                       FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            <Border Grid.Column="1" Background="{Binding ActivityBrush}"
                                                    CornerRadius="3" Padding="5,1" Margin="8,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Detail}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding CountLabel}"
                                                       FontSize="10" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</Page>
