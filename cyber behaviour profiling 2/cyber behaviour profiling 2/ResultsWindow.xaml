<ui:FluentWindow
    x:Class="cyber_behaviour_profiling_2.ResultsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Session Results"
    Width="820" Height="680"
    MinWidth="600" MinHeight="400"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Session Results" Grid.Row="0" Margin="-16,-8,-16,0"/>

        <!-- Report viewer -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Margin="0,10,0,10">
            <FlowDocumentScrollViewer x:Name="ReportViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsToolBarVisible="False"
                                      Padding="24,18,24,18"/>
        </Border>

        <!-- Bottom action bar -->
        <Border Grid.Row="2"
                CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="16,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Export results:"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="DownloadReportButton"
                               Content="Download Report (.txt)"
                               Appearance="Secondary"
                               Margin="0,0,8,0"
                               Click="DownloadReport_Click"/>
                    <ui:Button x:Name="DownloadMetadataButton"
                               Content="Download Metadata (.txt)"
                               Appearance="Secondary"
                               Click="DownloadMetadata_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
